# Copy to .env for local dev (.env is gitignored). In dev/staging/prod on ECS these same
# variables are injected from AWS Secrets Manager via the task definition — see
# docs/architecture/config-and-secrets.md. The app only ever reads them from the environment.

NODE_ENV=development
PORT=3000

# Database components. The app assembles the connection string from these (buildDatabaseUrl).
# On ECS these are injected straight from the RDS-managed secret — nothing to hand-populate.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=hms
DATABASE_PASSWORD=hms
DATABASE_NAME=hms

# Cognito — single shared user pool (ap-south-2 = Hyderabad, for India data residency).
# Local dev placeholders are fine until a real pool exists; token verification will 401.
AWS_REGION=ap-south-2
COGNITO_USER_POOL_ID=ap-south-2_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
