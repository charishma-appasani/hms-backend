# Dependencies — reinstalled in-container via `npm ci`.
# (Also stops `COPY . .` from clobbering the freshly installed /app/node_modules.)
node_modules
**/node_modules

# Build output — regenerated by `npm run build` inside the image.
dist

# Infrastructure / CDK — not part of the app image (Dockerfile also rm -rf's it).
# Excludes infrastructure/node_modules and cdk.out from the build context.
infrastructure

# Secrets & local env — must never be baked into the image.
.env
.env.*

# Version control & CI.
.git
.gitignore
.github

# Docs & meta.
docs
*.md

# Editor / OS noise.
.vscode
.idea
.DS_Store

# Tests & coverage.
test
coverage
**/*.spec.ts
**/*.e2e-spec.ts

# Logs.
*.log
npm-debug.log*
